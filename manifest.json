{
  "manifest_version": 3,
  "name": "Next UI - AI Assistant",
  "version": "1.0",
  "description": "AI 기반 웹 UI 가이드",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon.png"
  },
  "options_page": "options.htm",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
